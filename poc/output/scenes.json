    {
      "scene_id": 2,
      "summary": "男が興奮した様子で誰かに掛け金を申し出ているシーン。汗をかき、必死に何かを訴えている様子がうかがえる。全財産を持ち込んだとも主張している。",
      "keywords": [
        "掛け金",
        "人生",
        "財産",
        "訴え",
        "興奮"
      ]
    },
    {
      "scene_id": 3,
      "summary": "男性が興奮した様子で「人生を変えさせてくれ」と繰り返し叫んでいる。周囲には建物があり、金銭的な取引の場である可能性がある。全財産を持ち込んだとも語っている。",
      "keywords": [
        "人生",
        "財産",
        "掛け",
        "取引",
        "男性"
      ]
    },
    {
      "scene_id": 4,
      "summary": "男が誰かに近づき、熱心に何かを訴えている。全財産を持ってきたと話し、相手の人生を変えさせろと懇願する様子がうかがえる。",
      "keywords": [
        "懇願",
        "財産",
        "人生",
        "男",
        "説得"
      ]
    },
    {
      "scene_id": 5,
      "summary": "男性が焦燥感に駆られ、独り言のように「新しい人生を駆け出してくれ」と繰り返している。周囲は暗く、緊迫した雰囲気を感じさせる。男性は「今日休み」と繰り返し呟いている。",
      "keywords": [
        "男性",
        "独り言",
        "緊迫感",
        "新しい人生",
        "休み"
      ]
    },
    {
      "scene_id": 6,
      "summary": "男性が焦燥感に駆られ、独り言のように繰り返している。周囲には暗い場所が見えるが、人物は不明。新しい人生を求め、逃げ出すことを願っている様子がうかがえる。",
      "keywords": [
        "男性",
        "逃避",
        "独り言",
        "焦燥感",
        "暗闇"
      ]
    },
    {
      "scene_id": 7,
      "summary": "男性が荒れた様子で、新しい人生を求める言葉を繰り返し唱えている。周囲は暗く、焦燥感と混乱が伝わるシーン。彼は今日を休むと呟いている。",
      "keywords": [
        "男性",
        "人生",
        "混乱",
        "逃避",
        "繰り返し"
      ]
    },
    {
      "scene_id": 8,
      "summary": "オフィスで社員が月曜日の休日の取り扱いについて話し合っている。祝日も関係なく、月曜日のみ休みにするという方針であり、振り替え休日についてはシステム上で対応できないため、月曜を休日とするようだ。",
      "keywords": [
        "月曜日",
        "休日",
        "祝日",
        "振り替え",
        "オフィス"
      ]
    },
    {
      "scene_id": 9,
      "summary": "オフィスで複数の人物が就業時間や休日に関する議論をしている。週何回休みを取りたいか、システム構築の必要性や祝日と月曜日の休みに関する意見が交わされている。また、「ロンティの上ロンティ」という言葉から、服装に関する指示が出されている。",
      "keywords": [
        "休日",
        "就業時間",
        "システム",
        "ロンティ",
        "議論"
      ]
    },
    {
      "scene_id": 10,
      "summary": "複数の人物が、服の柄について話している。ロンティの上に着るトレーナーの変更を指示し、明日行うかどうかを誰に確認すべきか議論している。背景には何らかの施設が見える。",
      "keywords": [
        "ロンティ",
        "トレーナー",
        "明日",
        "指示",
        "裏口"
      ]
    },
    {
      "scene_id": 11,
      "summary": "複数の人物が、施設への裏口の利用について話し合っている。ロンティの上に着るトレーナーや、明日勤務する担当など、具体的な話題が出ている。月曜日の祝日休みであることについても触れられている。",
      "keywords": [
        "裏口",
        "ロンティ",
        "勤務",
        "祝日",
        "月曜日"
      ]
    },
    {
      "scene_id": 12,
      "summary": "従業員が裏口から入り、月曜日が休みであることの説明をしている場面。人件費の問題について議論があり、「人材を変えろ」という指示が出ている。店員とのバトルについて触れられている。",
      "keywords": [
        "裏口",
        "月曜日",
        "人材",
        "バトル",
        "人件費"
      ]
    },
    {
      "scene_id": 13,
      "summary": "店員とバトルはしないという男性が、客同士の喧嘩について説明している。相手が何本持っているのか尋ねられ、料金について疑問を投げかけている場面。",
      "keywords": [
        "バトル",
        "客",
        "料金",
        "喧嘩",
        "店員"
      ]
    },
    {
      "scene_id": 14,
      "summary": "若い男性たちが路上で口論しているシーン。一人が「バトルしろ」と挑発し、別の人物の所持金に言及している。騒動について店長への報告をめぐって言い争っており、年齢を問い合わされる場面がある。",
      "keywords": [
        "口論",
        "バトル",
        "店長",
        "年齢",
        "バイト"
      ]
    },
    {
      "scene_id": 15,
      "summary": "男性が机に向かい、書類を確認している。同僚らしき人物から「ありがとうございます」と声をかけられている。作業を急ぐ様子が窺える。",
      "keywords": [
        "机",
        "書類",
        "男性",
        "感謝",
        "作業"
      ]
    },
    {
      "scene_id": 16,
      "summary": "男性がデスクで作業している。祝日でも仕事に取り組んでいる様子で、「ありがとうございます」と誰かに言われている。",
      "keywords": [
        "デスク",
        "男性",
        "仕事",
        "感謝",
        "祝日"
      ]
